# =====================================================
# Docker Environment Variables - Copy to .env
# =====================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres          # CHANGE IN PRODUCTION
POSTGRES_DB=analysisdb

# Backend Security
SECRET_KEY=change-this-secret-key-in-production   # MUST CHANGE
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend port (default: 80)
FRONTEND_PORT=80
